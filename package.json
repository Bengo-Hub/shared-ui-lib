{
  "name": "@bengo-hub/shared-ui-lib",
  "version": "0.1.0",
  "description": "Shared UI components for the BengoBox/UzaPoint platform. Treasury payment modal, SSO login modal, logistics tracking modal — all iframe-embedded with postMessage real-time events.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./payments": {
      "types": "./dist/components/payments/index.d.ts",
      "import": "./dist/components/payments/index.js",
      "require": "./dist/components/payments/index.cjs"
    },
    "./auth": {
      "types": "./dist/components/auth/index.d.ts",
      "import": "./dist/components/auth/index.js",
      "require": "./dist/components/auth/index.cjs"
    },
    "./tracking": {
      "types": "./dist/components/tracking/index.d.ts",
      "import": "./dist/components/tracking/index.js",
      "require": "./dist/components/tracking/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Bengo-Hub/shared-ui-lib.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "license": "MIT",
  "keywords": [
    "treasury",
    "payments",
    "sso",
    "tracking",
    "iframe",
    "postmessage",
    "react",
    "bengobox",
    "uzapoint"
  ]
}
